# Optional backend toggles.

# Local LLM provider for planner answers.
# Use "mock" for local demos without external API packages/keys.
# Options: mock, anthropic, featherless, gemini
LLM_PROVIDER=mock

# Required only when LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
