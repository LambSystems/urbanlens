# Optional backend toggles.

# Keep this off for fast demo/API startup.
# Set to 1 when you want POST /analysis to run one live hybrid_thermal inference
# and attach the generated preview URL to hotspot evidence.
THERMALGEN_ENABLE_LIVE_THERMAL=0

# Optional explicit RGB image for live thermal inference.
# Leave blank to use the first image in backend/data/hybrid_thermal/RGB_to_thermal_dataset/Test/RGB.
THERMALGEN_DEMO_IMAGE=

