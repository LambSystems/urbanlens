{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "commands": [
        {
          "cmd": "python -m pip install --upgrade pip && python -m pip install -r requirements-deploy.txt",
          "customName": "Install demo backend dependencies"
        }
      ]
    }
  },
  "deploy": {
    "startCommand": "uvicorn app.main:app --host 0.0.0.0 --port $PORT"
  }
}
