# UrbanLens local development environment.
#
# Copy this file to .env at the repository root, then fill only the values
# needed for the path you want to run. scripts/sync-env.ps1 writes service
# env files for backend/ and frontend/ from this root file.

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Backend LLM provider.
# Use "mock" for no-key local demos and deterministic smoke checks.
# Options: mock, anthropic, featherless, gemini
LLM_PROVIDER=mock

# Hosted portfolio demo mode.
# true bypasses live LLM calls and heavy ThermalGen inference with fixed fixtures.
DEMO_MODE=false

# Anthropic, optional unless LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_VISION_MODEL=claude-sonnet-4-20250514

# Gemini / Google ADK, optional unless LLM_PROVIDER=gemini or session agent flow is used.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Featherless, optional unless LLM_PROVIDER=featherless.
FEATHERLESS_API_KEY=
FEATHERLESS_MODEL=Qwen/Qwen2.5-7B-Instruct
FEATHERLESS_HTTP_REFERER=https://urbanlens.local
FEATHERLESS_X_TITLE=UrbanLens

# ElevenLabs voice briefing, optional.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL_ID=eleven_flash_v2_5
